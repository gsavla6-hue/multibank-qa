<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultiBank Cross-Browser Suite" verbose="1" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="com.multibank.listeners.TestListener"/>
    </listeners>

    <!-- Chrome -->
    <test name="Chrome – Navigation">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Chrome – Trading">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>

    <!-- Firefox -->
    <test name="Firefox – Navigation">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Firefox – Trading">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>

    <!-- Edge -->
    <test name="Edge – Navigation">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

</suite>
