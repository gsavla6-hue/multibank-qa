<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultiBank Regression Suite" verbose="1" parallel="classes" thread-count="3">

    <listeners>
        <listener class-name="com.multibank.listeners.TestListener"/>
    </listeners>

    <test name="Navigation Tests" preserve-order="true">
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Trading Tests" preserve-order="true">
        <classes>
            <class name="com.multibank.tests.TradingTest"/>
        </classes>
    </test>

    <test name="Content Validation Tests" preserve-order="true">
        <classes>
            <class name="com.multibank.tests.ContentValidationTest"/>
        </classes>
    </test>

    <test name="Link Validation Tests" preserve-order="true">
        <classes>
            <class name="com.multibank.tests.LinkValidationTest"/>
        </classes>
    </test>

    <test name="Responsive Layout Tests" preserve-order="true">
        <classes>
            <class name="com.multibank.tests.ResponsiveLayoutTest"/>
        </classes>
    </test>

    <test name="Performance Tests" preserve-order="true">
        <classes>
            <class name="com.multibank.tests.PerformanceTest"/>
        </classes>
    </test>

    <test name="Accessibility Tests" preserve-order="true">
        <classes>
            <class name="com.multibank.tests.AccessibilityTest"/>
        </classes>
    </test>

</suite>
