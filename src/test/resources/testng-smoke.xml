<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultiBank Smoke Suite" verbose="1" parallel="none">

    <listeners>
        <listener class-name="com.multibank.listeners.TestListener"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.multibank.tests.NavigationTest">
                <methods>
                    <include name="testPageLoads"/>
                    <include name="testNavBarPresent"/>
                </methods>
            </class>
            <class name="com.multibank.tests.TradingTest">
                <methods>
                    <include name="testSpotSectionPresent"/>
                </methods>
            </class>
            <class name="com.multibank.tests.ContentValidationTest">
                <methods>
                    <include name="testAppStoreLinkPresent"/>
                    <include name="testGooglePlayLinkPresent"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
